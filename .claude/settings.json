{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/jisu/Desktop/jigu.dev && npx tsc --noEmit 2>&1 | head -20"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/jisu/Desktop/jigu.dev && FILES=$(git diff --name-only HEAD 2>/dev/null | grep -E '\\.(ts|tsx)$' | head -5 | tr '\\n' ' ') && [ -n \"$FILES\" ] && npx eslint --max-warnings=0 $FILES 2>&1 | tail -10 || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/jisu/Desktop/jigu.dev && git status --short"
          }
        ]
      }
    ]
  }
}
